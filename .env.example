# =============================================================================
# IDT Sync Monitor – Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must NEVER be committed to source control.
# =============================================================================

# ─── Head Office Oracle DB ────────────────────────────────────────────────────
# Dedicated read-only user for the HO database (queries only, no DML).
HO_DB_USER=your_ho_db_user
HO_DB_PASSWORD=your_ho_db_password
HO_DB_CONNECTSTRING=<host>:<port>/<service>   # e.g. 192.168.16.9:1521/COINSDB

# ─── Outlet Oracle DB (applied to all branch servers) ─────────────────────────
OUTLET_DB_USER=your_outlet_db_user
OUTLET_DB_PASSWORD=your_outlet_db_password
OUTLET_DB_PORT=1521
OUTLET_DB_SERVICE=XE

# ─── SSH – Key-based Auth (preferred, new servers) ────────────────────────────
# The system tries key auth first, then falls back to password auth.
SSH_USER_KEY=your_ssh_key_username
SSH_KEY_PATH=/absolute/path/to/private_key   # e.g. D:\Projects\IDT_status\id_rsa

# ─── SSH – Password-based Auth (fallback, old servers) ────────────────────────
SSH_USER_PWD=root
SSH_PASSWORD=your_ssh_password
SSH_KEY_PATH_TILL_OLD=/absolute/path/to/root-rsa-till

# ─── SSH – Port ───────────────────────────────────────────────────────────────
SSH_PORT=22
